{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "delta-engage config",
  "type": "object",
  "required": ["positioning", "icp", "platforms", "opportunities_per_run"],
  "properties": {
    "positioning": { "type": "string", "description": "one-line what-you-do" },
    "icp": {
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "context": { "type": "string" },
        "pain": { "type": "string" },
        "pain_language": {
          "type": "array", "items": { "type": "string" },
          "description": "phrases the buyer uses for the problem; seeds topics (demand, not category)"
        },
        "notes": { "type": "string" }
      }
    },
    "exclude_signals": {
      "type": "array", "items": { "type": "string" },
      "description": "markers of non-buyers (competitors/peers/sales content) → tagged peer_competitor, routed to partnerships"
    },
    "platforms": {
      "type": "array",
      "items": { "enum": ["reddit", "linkedin", "x"] }
    },
    "cadence": { "type": "string", "description": "mon_thu | weekly | custom string (display only)" },
    "opportunities_per_run": { "type": "integer", "minimum": 1, "default": 10 },
    "engagement_posture": {
      "enum": ["question-led", "experience-led", "respectful-challenge", "mix"],
      "default": "mix"
    },
    "primary_goal": { "enum": ["brand", "pipeline"], "default": "brand" },
    "seed_accounts": {
      "type": "object",
      "properties": {
        "reddit_subreddits": { "type": "array", "items": { "type": "string" } },
        "linkedin_profiles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "watchlist": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "handle": { "type": "string" },
          "platform": { "enum": ["reddit", "linkedin", "x"] },
          "worthy_count": { "type": "integer" },
          "last_worthy_run": { "type": "string", "description": "ISO date" }
        }
      }
    },
    "topics": { "type": "array", "items": { "type": "string" } },
    "author_voice": {
      "type": "object",
      "description": "optional; user's own voice/credibility from their public LinkedIn (Stage 1b)",
      "properties": {
        "linkedin_url": { "type": "string" },
        "tone": { "type": "string" },
        "themes": { "type": "array", "items": { "type": "string" } },
        "credibility": { "type": "string" }
      }
    },
    "reddit_account_status": {
      "enum": ["established", "new"],
      "default": "established",
      "description": "calibrates Reddit safety advice (see references/reddit-safety.md)"
    },
    "delivery": {
      "type": "object",
      "description": "where the recurring digest is delivered (see references/delivery.md)",
      "properties": {
        "channel": { "enum": ["in_app", "slack", "notion"], "default": "in_app" },
        "slack_channel": { "type": "string", "description": "Slack channel or DM target" },
        "notion_target": { "type": "string", "description": "Notion page ID/URL or database ID to append runs to" }
      }
    },
    "providers": {
      "type": "object",
      "properties": {
        "reddit": { "enum": ["apify", "official"], "default": "apify" },
        "linkedin": { "enum": ["apify_cookieless"], "default": "apify_cookieless",
          "description": "cookieless only — no session actors (see references/DECISIONS.md)" }
      }
    },
    "run_history": {
      "type": "array",
      "description": "appended each run by watchlist_tally.py --apply-history",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string" },
          "platforms": { "type": "array", "items": { "type": "string" } },
          "worthy_authors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "handle": { "type": "string" },
                "platform": { "type": "string" },
                "worthy_count": { "type": "integer" }
              }
            }
          }
        }
      }
    }
  }
}
